{
    "name": "codecov-management-skill",
    "version": "1.0.0",
    "private": false,
    "description": "Codex skill for managing Codecov coverage, API inspection, uploads, flags, reports, and repository configuration.",
    "keywords": [
        "agent-skill",
        "agent-skills",
        "ai-agent",
        "claude-code",
        "codex",
        "codecov",
        "coverage",
        "cursor",
        "gemini-cli",
        "github-copilot",
        "openai",
        "opencode",
        "test-coverage",
        "universal",
        "zed"
    ],
    "homepage": "https://github.com/Nick2bad4u/Codecov-Skill#readme",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/Codecov-Skill/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/Codecov-Skill.git"
    },
    "license": "Unlicense",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://github.com/Nick2bad4u)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "type": "module",
    "files": [
        "skills/codecov-management/SKILL.md",
        "skills/codecov-management/LICENSE.txt",
        "skills/codecov-management/agents/",
        "skills/codecov-management/assets/",
        "skills/codecov-management/references/",
        "skills/codecov-management/scripts/*.py",
        "CHANGELOG.md",
        "CONTRIBUTING.md",
        "README.md",
        "SECURITY.md"
    ],
    "scripts": {
        "changelog:generate": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/Codecov-Skill --output CHANGELOG.md",
        "changelog:preview": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/Codecov-Skill --unreleased",
        "changelog:release-notes": "git cliff --config node_modules/gitcliff-config-nick2bad4u/cliff.toml --github-repo Nick2bad4u/Codecov-Skill --current",
        "check:python": "npm run lint:python && npm run typecheck:python && npm run test:python && npm run compile:python",
        "check:python:unsafe": "npm run lint:python:unsafe && npm run typecheck:python && npm run test:python && npm run compile:python",
        "compile:python": "python -m compileall -q -x \"[\\\\/]\\.\" skills/codecov-management/scripts tests",
        "format:python": "npm run ruff:format && npm run ruff:fix",
        "lint:gitleaks": "gitleaks dir --config .gitleaks.toml .",
        "lint:jscpd": "jscpd --config node_modules/jscpd-config-nick2bad4u/jscpd.json",
        "lint:lychee": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml .",
        "lint:lychee:smoke": "lychee --config node_modules/lychee-config-nick2bad4u/lychee.toml --dump-inputs README.md",
        "lint:package-json": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:python": "npm run ruff:check && npm run ruff:format:check",
        "lint:python:unsafe": "npm run ruff:check:unsafe && npm run ruff:fix:unsafe",
        "lint:remark": "remark . --frail --ignore-path .remarkignore",
        "lint:remark:fix": "remark . --ignore-path .remarkignore --output",
        "lint:yamllint": "yamllint -c .yamllint .",
        "pack:dry-run": "npm pack --dry-run",
        "publish:local": "npm run release:verify && npm publish --access public --provenance",
        "pyright": "pyright",
        "python:bootstrap": "python -m pip install -r requirements-dev.txt",
        "python:venv": "python -m venv .venv && .venv\\Scripts\\activate && python -m pip install --upgrade pip && python -m pip install -r requirements-dev.txt",
        "python:venv:activate": ". .\\.venv\\Scripts\\Activate.ps1",
        "python:venv:deactivate": ". .\\.venv\\Scripts\\Deactivate.ps1",
        "release:verify": "npm run validate && npm run test && npm run pack:dry-run",
        "ruff:check": "ruff check skills/codecov-management/scripts tests",
        "ruff:check:unsafe": "ruff check --unsafe-fixes skills/codecov-management/scripts tests",
        "ruff:fix": "ruff check --fix skills/codecov-management/scripts tests",
        "ruff:fix:unsafe": "ruff check --fix --unsafe-fixes skills/codecov-management/scripts tests",
        "ruff:format": "ruff format skills/codecov-management/scripts tests",
        "ruff:format:check": "ruff format --check skills/codecov-management/scripts tests",
        "skillcheck": "skillcheck --history skills/codecov-management/SKILL.md --fail-on-regression",
        "test": "npm run test:python",
        "test:python": "pytest",
        "typecheck:python": "mypy && pyright",
        "update-actions": "npx actions-up --yes --style sha",
        "update-deps": "ncu --configFileName .ncurc.json --configFilePath node_modules/ncu-config-nick2bad4u && npm update --force && npm install --force",
        "validate": "node tools/validate-skill-package.mjs"
    },
    "devDependencies": {
        "@microsoft/tsdoc-config": "^0.18.1",
        "eslint-config-nick2bad4u": "^5.0.0",
        "git-cliff": "^2.13.1",
        "gitcliff-config-nick2bad4u": "^1.3.0",
        "gitleaks-config-nick2bad4u": "^1.0.4",
        "jscpd": "^5.0.12",
        "jscpd-config-nick2bad4u": "^1.1.0",
        "lychee-config-nick2bad4u": "^2.0.0",
        "ncu-config-nick2bad4u": "^0.2.0",
        "npm-check-updates": "^22.2.9",
        "npm-package-json-lint": "^10.4.1",
        "npm-package-json-lint-config-nick2bad4u": "^1.0.4",
        "prettier": "^3.9.5",
        "prettier-config-nick2bad4u": "^1.1.1",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.1.3",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.1.2",
        "stylelint": "^17.14.0",
        "stylelint-config-nick2bad4u": "^1.0.20",
        "tsdoc-config-nick2bad4u": "^1.0.6",
        "yamllint-config-nick2bad4u": "^1.1.1"
    },
    "engines": {
        "node": ">=22.14"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "codexSkill": {
        "name": "codecov-management",
        "path": "skills/codecov-management",
        "githubReleaseAssetPrefix": "codecov-skill"
    }
}
